{
  "name": "hyot-software-center",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:schemas && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write src",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "build:search-index": "tsx scripts/build-search-index.ts",
    "build:og": "tsx scripts/generate-og-images.ts",
    "build:sitemap": "tsx scripts/generate-sitemap.ts",
    "build:rss": "tsx scripts/generate-rss.ts",
    "build:icons": "tsx scripts/generate-icons.ts",
    "sync:release": "tsx scripts/sync-release.ts",
    "test:a11y": "tsx scripts/test-a11y.ts",
    "test:lighthouse": "lhci autorun",
    "admin": "cd admin && npm install --prefix . && npm run dev",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.525.0",
    "next": "^15.3.5",
    "next-intl": "^4.3.4",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.3.1",
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^22.16.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vercel/og": "^0.6.8",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.5",
    "husky": "^9.1.7",
    "playwright": "^1.52.0",
    "prettier": "^3.6.2",
    "serve": "^14.0.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
