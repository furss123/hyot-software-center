{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "i18n.schema.json",
  "title": "I18nMessages",
  "type": "object",
  "required": ["nav", "hero", "software", "search", "theme", "locale", "footer", "error"],
  "properties": {
    "nav": {
      "type": "object",
      "required": ["home", "software", "about"],
      "properties": {
        "home": { "type": "string" },
        "software": { "type": "string" },
        "about": { "type": "string" }
      }
    },
    "hero": {
      "type": "object",
      "required": ["title", "subtitle", "cta"],
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "cta": { "type": "string" }
      }
    },
    "software": {
      "type": "object",
      "required": ["download", "version", "channel", "changelog", "requirements", "license"],
      "properties": {
        "download": { "type": "string" },
        "version": { "type": "string" },
        "channel": { "type": "string" },
        "changelog": { "type": "string" },
        "requirements": { "type": "string" },
        "license": { "type": "string" }
      }
    },
    "search": {
      "type": "object",
      "required": ["placeholder", "noResults"],
      "properties": {
        "placeholder": { "type": "string" },
        "noResults": { "type": "string" }
      }
    },
    "theme": {
      "type": "object",
      "required": ["toggle"],
      "properties": {
        "toggle": { "type": "string" }
      }
    },
    "locale": {
      "type": "object",
      "required": ["toggle"],
      "properties": {
        "toggle": { "type": "string" }
      }
    },
    "footer": {
      "type": "object",
      "required": ["copyright"],
      "properties": {
        "copyright": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "required": ["notFound", "generic"],
      "properties": {
        "notFound": { "type": "string" },
        "generic": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
