{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "site-config.schema.json",
  "title": "SiteConfig",
  "type": "object",
  "required": [
    "name",
    "description",
    "url",
    "basePath",
    "defaultLocale",
    "locales",
    "author",
    "social",
    "accentColor"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "url": { "type": "string", "format": "uri" },
    "basePath": { "type": "string" },
    "defaultLocale": { "type": "string", "enum": ["ko", "en"] },
    "locales": {
      "type": "array",
      "items": { "type": "string", "enum": ["ko", "en"] },
      "minItems": 1
    },
    "author": {
      "type": "object",
      "required": ["name", "url"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "social": {
      "type": "object",
      "required": ["github"],
      "properties": {
        "github": { "type": "string", "format": "uri" }
      }
    },
    "accentColor": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
  },
  "additionalProperties": false
}
